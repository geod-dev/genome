{
    "include": ["src"],
    "compilerOptions": {
        "target": "ES2022",

        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "strict": true,
        "skipLibCheck": true,

        "rootDir": "src",
        "outDir": "dist",

        "paths": {
            "@/*": ["./src/*"]
        },

        "experimentalDecorators": false,

        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true
    }
}
